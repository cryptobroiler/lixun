pkgname=lupa
pkgver=0.1.0
pkgrel=1
pkgdesc="Spotlight-like launcher for Linux"
arch=("x86_64")
url="https://repo.dkp.hk/denis/lupa"
license=("MIT")
depends=("gtk4" "libadwaita" "gtk4-layer-shell")
makedepends=("rust" "cargo")
source=("${pkgname}-${pkgver}.tar.gz::https://repo.dkp.hk/denis/lupa/archive/v${pkgver}.tar.gz")
sha256sums=("SKIP")

build() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  cargo build --release
}

package() {
  install -Dm755 "target/release/lupad" "${pkgdir}/usr/bin/lupad"
  install -Dm755 "target/release/lupa" "${pkgdir}/usr/bin/lupa"
  install -Dm644 "packaging/systemd/lupad.service" "${pkgdir}/usr/lib/systemd/user/lupad.service"
  install -Dm644 "packaging/desktop/lupa.desktop" "${pkgdir}/usr/share/applications/lupa.desktop"
}
