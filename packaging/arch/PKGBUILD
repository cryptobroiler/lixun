# Maintainer: Шабилиск <shabi@dkp.hk>
pkgname=lupa-bin
pkgver=0.2.0
pkgrel=1
pkgdesc="Spotlight-like launcher for Linux (pre-built binary)"
arch=("x86_64")
url="https://repo.dkp.hk/denis/lupa"
license=("MIT")
depends=("gtk4" "gtk4-layer-shell" "poppler" "zstd" "sqlite")
optdepends=("antiword: .doc extraction"
            "catdoc: .doc extraction"
            "libreoffice-fresh: .docx/.xlsx/.pptx extraction")
provides=("lupa")
conflicts=("lupa")

# Local tarball — replace with release URL for distribution:
# source=("https://repo.dkp.hk/lupa/lupa-${pkgver}-x86_64.tar.gz")
source=("lupa-${pkgver}-x86_64.tar.gz::file:///home/cryptobroiler/Developer/lupa/packaging/arch/lupa-${pkgver}-x86_64.tar.gz" "systemd-lupad.service" "lupa.desktop")
md5sums=("SKIP" "SKIP" "SKIP")

package() {
  install -Dm755 "lupad" "$pkgdir/usr/bin/lupad"
  install -Dm755 "lupa" "$pkgdir/usr/bin/lupa"
  install -Dm755 "lupa-gui" "$pkgdir/usr/bin/lupa-gui"
  install -Dm644 "${srcdir}/systemd-lupad.service" "$pkgdir/usr/lib/systemd/user/lupad.service"
  install -Dm644 "${srcdir}/lupa.desktop" "$pkgdir/usr/share/applications/lupa.desktop"
}
