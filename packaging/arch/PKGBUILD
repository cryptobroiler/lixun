# Maintainer: Шабилиск <shabi@dkp.hk>
pkgname=lixun-bin
pkgver=0.3.0
pkgrel=2
pkgdesc="Spotlight-like launcher for Linux (pre-built binary)"
arch=("x86_64")
url="https://repo.dkp.hk/denis/lixun"
license=("MIT")
depends=("gtk4" "gtk4-layer-shell" "poppler" "zstd" "sqlite")
optdepends=("antiword: .doc extraction"
            "catdoc: .doc extraction"
            "libreoffice-fresh: .docx/.xlsx/.pptx extraction + preview"
            "tesseract: OCR engine for images and scan PDFs (enable via [ocr].enabled in config)"
            "tesseract-data-eng: English OCR language pack"
            "tesseract-data-rus: Russian OCR language pack"
            "tesseract-data-chi_sim: Simplified Chinese OCR language pack"
            "gst-plugins-base: GStreamer foundation (preview plugin: av, animated images)"
            "gst-plugins-good: common codecs (preview plugin: av, animated images)"
            "gst-libav: FFmpeg-backed decoders (preview plugin: GIF/WebP animation, MP3/MP4 playback)"
            "xdg-terminal-exec: required by the shell plugin (> prefix) to launch commands in the user's terminal emulator; honours \$TERMINAL and ~/.config/xdg-terminals.list")
provides=("lixun")
conflicts=("lixun")

# Local tarball — replace with release URL for distribution:
# source=("https://repo.dkp.hk/lixun/lixun-${pkgver}-x86_64.tar.gz")
source=("lixun-${pkgver}-x86_64.tar.gz::file:///home/cryptobroiler/Developer/lixun/packaging/arch/lixun-${pkgver}-x86_64.tar.gz" "systemd-lixund.service" "app.lixun.daemon.desktop" "app.lixun.daemon.svg")
md5sums=("SKIP" "SKIP" "SKIP" "SKIP")

package() {
  install -Dm755 "lixund" "$pkgdir/usr/bin/lixund"
  install -Dm755 "lixun" "$pkgdir/usr/bin/lixun"
  install -Dm755 "lixun-gui" "$pkgdir/usr/bin/lixun-gui"
  install -Dm755 "lixun-preview" "$pkgdir/usr/bin/lixun-preview"
  install -Dm644 "${srcdir}/systemd-lixund.service" "$pkgdir/usr/lib/systemd/user/lixund.service"
  install -Dm644 "${srcdir}/app.lixun.daemon.desktop" "$pkgdir/usr/share/applications/app.lixun.daemon.desktop"
  install -Dm644 "${srcdir}/app.lixun.daemon.svg" "$pkgdir/usr/share/icons/hicolor/scalable/apps/app.lixun.daemon.svg"
}
