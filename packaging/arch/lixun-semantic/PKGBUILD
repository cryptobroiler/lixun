# Maintainer: Denis Kopin <deng@lixun.app>
pkgname=lixun-semantic
pkgver=0.6.0
pkgrel=1
pkgdesc="Lixun semantic sidecar worker: dense-vector hybrid retrieval via fastembed + LanceDB"
arch=('x86_64')
url="https://lixun.app"
license=('MIT OR Apache-2.0')
# Mirrors lixun PKGBUILD round-7 hypothesis: disable makepkg LTO so the
# static archives bundled by tikv-jemalloc-sys / zstd-sys keep their
# rustc-link-lib metadata at the final link line.
options=(!lto)
# The worker dlopens ONNX Runtime from inside fastembed; libgomp + liblzma
# come from gcc-libs and xz respectively. Hard pin to the matching lixun
# version: the IPC schema lives in lixun-semantic-proto and crosses the
# wire between lixund and the worker, so mismatched versions break the
# handshake. Bump in lockstep.
depends=("lixun=$pkgver" 'gcc-libs' 'xz')
makedepends=('rust' 'cargo' 'protobuf')
source=("lixun-$pkgver.tar.gz::https://github.com/dengkeping/lixun/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('058811d020495ac4fcc649c8e2f8a408afec9f4aa6f8da3fffb7f3a8a235e709')

prepare() {
  cd "$srcdir/lixun-$pkgver"
  export CARGO_TARGET_DIR="$srcdir/target"
  cargo fetch --locked
}

build() {
  cd "$srcdir/lixun-$pkgver"
  export CARGO_TARGET_DIR="$srcdir/target"
  # See lixun/PKGBUILD round-6 notes: force the rustc linker driver to
  # /usr/bin/gcc so cargo:rustc-link-lib=static=jemalloc_pic from the
  # tikv-jemalloc-sys build script lands in the final link line, and wipe
  # any stale build cache before the bundled .a archives are linked.
  export CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_LINKER=/usr/bin/gcc
  unset RUSTFLAGS CARGO_ENCODED_RUSTFLAGS
  cargo clean
  cargo build --release --frozen -p lixun-semantic-worker
}

package() {
  cd "$srcdir/lixun-$pkgver"
  install -Dm755 "$srcdir/target/release/lixun-semantic-worker" \
    "$pkgdir/usr/lib/lixun/lixun-semantic-worker"

  install -Dm644 LICENSE-MIT     "$pkgdir/usr/share/licenses/$pkgname/LICENSE-MIT"
  install -Dm644 LICENSE-APACHE  "$pkgdir/usr/share/licenses/$pkgname/LICENSE-APACHE"
}
